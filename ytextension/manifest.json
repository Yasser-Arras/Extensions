{
  "manifest_version": 3,
  "name": "YT Shorts Toolbox",
  "version": "1.0",
  "description": "Custom toolbar for YouTube Shorts with play/pause, speed, and more.",
  
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/shorts/*", "*://*.youtube.com/watch*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
  {
    "resources": ["src/assets/icons/*"],
    "matches": ["*://*.youtube.com/*"]
  }
]
}